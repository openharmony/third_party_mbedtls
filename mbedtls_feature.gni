# -----------------------------------------------------------------------------
# Dependency assertions (compile-time checked).
# -----------------------------------------------------------------------------

assert(!mbedtls_feature_gcm || mbedtls_feature_aes,
       "mbedtls_feature_gcm requires mbedtls_feature_aes")
assert(!mbedtls_feature_ccm || mbedtls_feature_aes,
       "mbedtls_feature_ccm requires mbedtls_feature_aes")
assert(!mbedtls_feature_chacha20 || mbedtls_feature_cipher,
       "mbedtls_feature_chacha20 requires mbedtls_feature_cipher")
assert(!mbedtls_feature_cmac || mbedtls_feature_cipher,
       "mbedtls_feature_cmac requires mbedtls_feature_cipher")
assert(!mbedtls_feature_ecdh || mbedtls_feature_ecp,
       "mbedtls_feature_ecdh requires mbedtls_feature_ecp")
assert(!mbedtls_feature_ecdsa || mbedtls_feature_ecp,
       "mbedtls_feature_ecdsa requires mbedtls_feature_ecp")
assert(!mbedtls_feature_ecjpake || mbedtls_feature_ecp,
       "mbedtls_feature_ecjpake requires mbedtls_feature_ecp")
assert(!mbedtls_feature_ecp || mbedtls_feature_bignum,
       "mbedtls_feature_ecp requires mbedtls_feature_bignum")
assert(!mbedtls_feature_rsa || mbedtls_feature_bignum,
       "mbedtls_feature_rsa requires mbedtls_feature_bignum")
assert(!mbedtls_feature_dhm || mbedtls_feature_bignum,
       "mbedtls_feature_dhm requires mbedtls_feature_bignum")
assert(!mbedtls_feature_pk || (mbedtls_feature_encoding && mbedtls_feature_md),
       "mbedtls_feature_pk requires mbedtls_feature_encoding and mbedtls_feature_md")
assert(!mbedtls_feature_pkcs5 || mbedtls_feature_md,
       "mbedtls_feature_pkcs5 requires mbedtls_feature_md")
assert(!mbedtls_feature_hkdf || mbedtls_feature_md,
       "mbedtls_feature_hkdf requires mbedtls_feature_md")
assert(!mbedtls_feature_x509 || (mbedtls_feature_pk && mbedtls_feature_encoding),
       "mbedtls_feature_x509 requires mbedtls_feature_pk and mbedtls_feature_encoding")
assert(!mbedtls_feature_ssl_tls12 ||
       (mbedtls_feature_cipher && mbedtls_feature_sha256 &&
        mbedtls_feature_pk && mbedtls_feature_entropy),
       "mbedtls_feature_ssl_tls12 requires cipher, sha256, pk, entropy")
assert(!mbedtls_feature_ssl_tls13 || mbedtls_feature_ssl_tls12,
       "mbedtls_feature_ssl_tls13 requires mbedtls_feature_ssl_tls12")
assert(!mbedtls_feature_ssl_srv || mbedtls_feature_ssl_tls12,
       "mbedtls_feature_ssl_srv requires mbedtls_feature_ssl_tls12")

