# ===========================================================================
# ws63 source-switch + feature-ization (feature module imported by mbedtls.gni).
#
# This whole block is intentionally appended standalone so
# that other product-form patches can edit the baseline above without conflict.
# It does NOT reassign MBEDTLS_SOURCES; BUILD.gn targets override `sources`
# per-target (via an end-of-block branch) when mbedtls_featureized = true.
#
# Evaluation order reminder: declare_args -> MBEDTLS_FEATURE_SOURCES/_feature_defines
# accumulation -> asserts -> public aggregates. All flag reads happen after the
# flags are declared, so tail placement is correct (GN is eager, top-to-bottom).
# ===========================================================================
declare_args() {
  # ---- Master switch + feature-ization (active only when mbedtls_featureized = true) ----
  # Note: all 39 features default to true. All corresponding algorithms are implemented in mbedtls v3.6.5
  # (verified: every feature .c exists and is non-empty). No unimplemented algorithm among the 39.
  mbedtls_featureized = false

  # OHOS mbedtls switch (source switch): separate from feature-ization.
  # When true: OHOS library named "mbedtls_ohos" -> linked to firmware (source switch active).
  # When false: named "mbedtls" -> firmware uses SDK v3.1.0 mbedtls (no source switch).
  # NOTE: Currently only adapted for ws63 (SDK cmake dual-gate in
  #   device/soc/hisilicon/ws63v100/sdk). Other SoCs have not been validated.
  # IMPORTANT: When enabled (true), feature-ization (mbedtls_featureized) MUST also be enabled to ensure
  #   complete algorithm coverage. Source switch alone (without feature-ization) is NOT supported.
  mbedtls_ohos_switch = false

  # Platform entropy poll: default false (ws63 has no FS, use hardware TRNG).
  # Set true via --gn-args mbedtls_platform_entropy=true (or config.json) on
  # products with a filesystem to enable mbedtls_platform_entropy_poll.
  mbedtls_platform_entropy = false

  # ---- Crypto layer features (default = mini-system config parity) ----
  mbedtls_feature_aes = true
  mbedtls_feature_aria = false
  mbedtls_feature_camellia = false
  mbedtls_feature_des = true
  mbedtls_feature_chacha20 = false
  mbedtls_feature_gcm = true
  mbedtls_feature_ccm = false
  mbedtls_feature_cmac = false
  mbedtls_feature_nist_kw = false
  mbedtls_feature_md5 = true
  mbedtls_feature_sha1 = true
  mbedtls_feature_sha256 = true
  mbedtls_feature_sha512 = true
  mbedtls_feature_sha3 = false
  mbedtls_feature_ripemd160 = false
  mbedtls_feature_hkdf = true
  mbedtls_feature_rsa = true
  mbedtls_feature_dhm = true
  mbedtls_feature_ecp = true
  # ECP curve sub-features (effective only when mbedtls_feature_ecp = true).
  # Default: all 13 curves enabled (true). A minimal curve set (e.g. SECP256R1 + CURVE25519 only)
  # requires explicitly disabling 11 curves via --gn-args mbedtls_feature_ecp_curve_*=false.
  # Each disabled curve saves ~2-3KB (curve params + per-curve mod funcs in ecp_curves.c,
  # not removable by --gc-sections due to curve lookup table / ecp_group_load switch).
  mbedtls_feature_ecp_curve_secp192r1 = true
  mbedtls_feature_ecp_curve_secp224r1 = true
  mbedtls_feature_ecp_curve_secp256r1 = true
  mbedtls_feature_ecp_curve_secp384r1 = true
  mbedtls_feature_ecp_curve_secp521r1 = true
  mbedtls_feature_ecp_curve_secp192k1 = true
  mbedtls_feature_ecp_curve_secp224k1 = true
  mbedtls_feature_ecp_curve_secp256k1 = true
  mbedtls_feature_ecp_curve_bp256r1 = true
  mbedtls_feature_ecp_curve_bp384r1 = true
  mbedtls_feature_ecp_curve_bp512r1 = true
  mbedtls_feature_ecp_curve_curve25519 = true
  mbedtls_feature_ecp_curve_curve448 = true
  mbedtls_feature_ecdh = true
  mbedtls_feature_ecdsa = true
  mbedtls_feature_ecjpake = false
  mbedtls_feature_pk = true
  mbedtls_feature_bignum = true
  mbedtls_feature_entropy = true
  mbedtls_feature_encoding = true
  mbedtls_feature_cipher = true
  mbedtls_feature_constant_time = false
  mbedtls_feature_md = true
  mbedtls_feature_pkcs5 = true
  mbedtls_feature_pkcs12 = false
  mbedtls_feature_psa_crypto = false
  mbedtls_feature_crypto_platform = true

  # ---- X.509 layer features ----
  mbedtls_feature_x509 = false
  mbedtls_feature_x509_write = false

  # ---- TLS layer features ----
  mbedtls_feature_ssl_tls12 = false
  mbedtls_feature_ssl_tls13 = false
  mbedtls_feature_ssl_srv = false
  mbedtls_feature_ssl_misc = false
}

