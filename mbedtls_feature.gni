# MBEDTLS_SOURCES is intentionally NOT reassigned here: the baseline gni above
# already set it to LIBRARYFILES (+ ohos_lite port extras). When feature-ization
# is on, each BUILD.gn target overrides `sources = MBEDTLS_FEATURE_SOURCES` via an
# end-of-block branch, so the baseline MBEDTLS_SOURCES is discarded only then.
#
# feature-ization (mbedtls_featureized) and source switch (mbedtls_ohos_switch)
# are decoupled; they can be independently toggled. However:
#   >>> Source switch (ohos_switch=true) MUST be used together with feature-ization
#       (featureized=true) to ensure complete algorithm coverage. <<<
# Source switch alone (without feature-ization) is NOT supported (config_liteos_m.h
# may miss algorithms like MBEDTLS_DHM_C needed by wpa_supplicant EAP-TLS).
# -----------------------------------------------------------------------------

if (mbedtls_featureized) {
  MBEDTLS_FEATURE_DEFINES = _feature_defines
} else {
  MBEDTLS_FEATURE_DEFINES = []
}

# Library output name: "mbedtls_ohos" when source switch on, else baseline "mbedtls".
# Read by BUILD.gn output_name (kept in place, only the value becomes this variable).
if (mbedtls_ohos_switch) {
  MBEDTLS_LIB_NAME = "mbedtls_ohos"
} else {
  MBEDTLS_LIB_NAME = "mbedtls"
}
